# Shared environment file for all services (single source of truth)

# PostgreSQL (Neon / managed Postgres)
DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>/<db_name>?sslmode=require

# AI / OpenRouter key used by ai-service
OPENAI_API_KEY=your_openai_or_openrouter_api_key
OPENROUTER_API_KEY=your_openrouter_api_key_optional_if_openai_key_used_above

# YouTube playlist integration
YOUTUBE_API_KEY=<your_youtube_data_api_key>

# Optional Atlas URI for non-docker local runs
# In Docker, profile-analysis-service uses mongodb://mongodb:27017/algonote
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority

# Clerk secret for gateway auth middleware
CLERK_SECRET_KEY=<your_clerk_secret_key>

# Clerk publishable key for client build/runtime
VITE_CLERK_PUBLISHABLE_KEY=<your_clerk_publishable_key>
